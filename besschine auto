</div>

<script>
var PASS = 'bess-13082007';
var products = JSON.parse(localStorage.getItem('besschine_v1') || '[]');
var orders = JSON.parse(localStorage.getItem('besschine_orders') || '[]');
var currentCatFilter = 'all';
var selectedBrand = null;
var selectedCategory = null;
var ordersFilter = 'all';
var currentPhotoBase64 = '';

var CATS = [
  {id:'Moteur', label:'Moteur & Transmission', icon:'⚙️', desc:'Pistons, courroies, embrayages, boîtes de vitesse'},
  {id:'Freinage', label:'Freinage & Suspension', icon:'🛞', desc:'Plaquettes, disques, amortisseurs, rotules'},
  {id:'Electricite', label:'Électricité & Éclairage', icon:'💡', desc:'Alternateurs, phares, capteurs, démarreurs'},
  {id:'Carrosserie', label:'Carrosserie', icon:'🏎️', desc:'Pare-chocs, ailes, capots, vitres'},
  {id:'Climatisation', label:'Climatisation', icon:'❄️', desc:'Compresseurs, condenseurs, filtres habitacle'},
  {id:'Entretien', label:'Entretien', icon:'🔩', desc:'Filtres, huiles, bougies, liquides'},
];

var BRANDS_DATA = {
  'Moteur': ['BYD','Chery','Geely','Great Wall','Changan','JAC','SAIC','Dongfeng','FAW','NIO','Haval','MG'],
  'Freinage': ['BYD','Chery','Geely','Haval','MG','JAC','Changan','Great Wall','SAIC','Dongfeng'],
  'Electricite': ['BYD','NIO','Xpeng','Chery','Geely','SAIC','Changan','BAIC','Great Wall','JAC'],
  'Carrosserie': ['BYD','Chery','Geely','Great Wall','MG','JAC','Changan','Dongfeng','SAIC','FAW'],
  'Climatisation': ['BYD','Chery','Geely','Haval','MG','Changan','JAC','NIO','Great Wall','BAIC'],
  'Entretien': ['BYD','Chery','Geely','Great Wall','Changan','Haval','MG','JAC','SAIC','Dongfeng','FAW'],
};

var BRAND_MODELS = {
  'BYD':'Han, Atto 3, Tang, Seal, Dolphin',
  'Chery':'Tiggo 7, Tiggo 8, Arrizo 5',
  'Geely':'Coolray, Azkarra, Emgrand',
  'Great Wall':'H6, Jolion, Poer, H9',
  'Changan':'CS35, CS55, CS75, Uni-T',
