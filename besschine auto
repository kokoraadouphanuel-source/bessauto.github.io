            <div class="ofilters">
              <button class="ofilter active" onclick="filterOrders('all',this)">Toutes</button>
              <button class="ofilter" onclick="filterOrders('new',this)">⏳ En attente</button>
              <button class="ofilter" onclick="filterOrders('done',this)">✅ Traitées</button>
