/* NAV */
nav{position:fixed;top:0;left:0;right:0;z-index:200;display:flex;align-items:center;justify-content:space-between;padding:0 40px;height:64px;background:var(--bd);box-shadow:0 2px 16px rgba(0,0,0,0.3);}
