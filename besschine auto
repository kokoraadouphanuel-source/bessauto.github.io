.tdel:hover{background:#fca5a5;}
.empty-t{text-align:center;padding:30px;color:var(--tl);font-style:italic;font-size:0.82rem;}

/* PHOTO UPLOAD */
.photo-upload-zone{border:2px dashed var(--g2);border-radius:8px;padding:18px;text-align:center;cursor:pointer;transition:all .2s;background:var(--g);position:relative;}
.photo-upload-zone:hover{border-color:var(--bl);background:var(--bvp);}
.photo-preview{display:none;position:relative;margin-top:8px;}
.photo-preview img{width:100%;height:130px;object-fit:cover;border-radius:6px;border:1px solid var(--g2);}
.photo-preview .rm-photo{position:absolute;top:5px;right:5px;background:rgba(0,0,0,0.55);color:#fff;border:none;border-radius:50%;width:24px;height:24px;cursor:pointer;font-size:0.8rem;display:flex;align-items:center;justify-content:center;}

/* COMMANDES ADMIN */
.orders-toolbar{display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;flex-wrap:wrap;gap:10px;}
.orders-toolbar h2{font-family:'Exo 2',sans-serif;font-size:1rem;font-weight:700;color:var(--tx);}
.ofilters{display:flex;gap:6px;flex-wrap:wrap;}
.ofilter{padding:5px 12px;border-radius:16px;border:1.5px solid var(--g2);background:var(--g);font-family:'Poppins',sans-serif;font-size:0.73rem;font-weight:600;cursor:pointer;transition:all .2s;}
.ofilter.active,.ofilter:hover{background:var(--bl);color:#fff;border-color:var(--bl);}
.clr-btn{background:#fee2e2;color:#dc2626;border:none;padding:6px 12px;border-radius:6px;font-family:'Exo 2',sans-serif;font-size:0.73rem;font-weight:700;cursor:pointer;}
.orders-list{display:flex;flex-direction:column;gap:12px;}
.order-card{background:#fff;border-radius:10px;border:1.5px solid var(--g2);overflow:hidden;}
.oc-head{display:flex;align-items:center;justify-content:space-between;padding:11px 15px;background:var(--bvp);border-bottom:1px solid var(--g2);flex-wrap:wrap;gap:6px;}
.oc-id{font-family:'Exo 2',sans-serif;font-size:0.76rem;font-weight:700;color:var(--b);}
.oc-date{font-size:0.7rem;color:var(--tl);}
.oc-status{font-size:0.66rem;font-weight:700;padding:3px 8px;border-radius:10px;}
.s-new{background:#fef3c7;color:#92400e;}
.s-done{background:#d1fae5;color:#065f46;}
.oc-body{padding:13px 15px;display:grid;grid-template-columns:1fr 1fr 1fr;gap:9px;}
.ocf .lbl{font-size:0.63rem;font-weight:700;letter-spacing:1px;text-transform:uppercase;color:var(--tl);margin-bottom:2px;}
.ocf .val{font-size:0.8rem;color:var(--tx);font-weight:500;word-break:break-word;}
.oc-foot{padding:10px 15px;border-top:1px solid var(--g2);display:flex;gap:7px;}
.btn-treat{background:var(--bl);color:#fff;border:none;padding:6px 12px;border-radius:5px;font-family:'Exo 2',sans-serif;font-size:0.73rem;font-weight:700;cursor:pointer;}
.btn-treat:hover{background:var(--bb);}
.btn-del-o{background:#fee2e2;color:#dc2626;border:none;padding:6px 11px;border-radius:5px;font-size:0.73rem;font-weight:700;cursor:pointer;}
.no-orders{text-align:center;padding:50px 20px;color:var(--tl);}
