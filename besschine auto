};

function saveProducts(){ localStorage.setItem('besschine_v1', JSON.stringify(products)); }
function saveOrders(){ localStorage.setItem('besschine_orders', JSON.stringify(orders)); }

// NAVIGATION
function showPage(id){
  document.querySelectorAll('.page').forEach(function(p){ p.classList.remove('active'); });
  document.getElementById(id).classList.add('active');
  window.scrollTo(0,0);
}
function scrollContact(){
  showPage('page-home');
  setTimeout(function(){ document.getElementById('section-contact').scrollIntoView({behavior:'smooth'}); }, 120);
}
function toggleMenu(){
  document.getElementById('mobileMenu').classList.toggle('open');
}
function closeMenu(){
  document.getElementById('mobileMenu').classList.remove('open');
}

// HOME - catégories
function initHome(){
  var grid = document.getElementById('homeCatsGrid');
  grid.innerHTML = '';
  CATS.forEach(function(c){
    var card = document.createElement('div');
    card.className = 'cat-card';
    card.setAttribute('data-catid', c.id);
    card.onclick = function(){ goToMarques(this.getAttribute('data-catid')); };
    var icon = document.createElement('div'); icon.className = 'cat-icon'; icon.textContent = c.icon;
    var h3 = document.createElement('h3'); h3.textContent = c.label;
    var p = document.createElement('p'); p.textContent = c.desc;
    var lnk = document.createElement('div'); lnk.className = 'cat-link'; lnk.textContent = 'Voir les marques →';
    card.appendChild(icon); card.appendChild(h3); card.appendChild(p); card.appendChild(lnk);
    grid.appendChild(card);
  });
}

// MARQUES
function goToMarques(catId){
  selectedCategory = catId;
  var cat = null;
  for(var i=0;i<CATS.length;i++){ if(CATS[i].id===catId){ cat=CATS[i]; break; } }
  if(!cat) return;
  document.getElementById('marquesTitle').textContent = cat.icon + ' ' + cat.label;
  document.getElementById('marquesSub').textContent = 'Sélectionnez la marque de votre véhicule';
  document.getElementById('brandsCatLabel').textContent = 'Marques disponibles – ' + cat.label;

  var brandNames = BRANDS_DATA[catId] || [];
  var grid = document.getElementById('brandsGrid');
  grid.innerHTML = '';

  brandNames.forEach(function(name){
    var card = document.createElement('div');
    card.className = 'brand-card';
    card.setAttribute('data-name', name);
    card.setAttribute('data-models', BRAND_MODELS[name] || '');
    card.setAttribute('data-other', '0');
    card.onclick = function(){ goToOrder(this); };

    var badge = document.createElement('div');
    badge.className = 'brand-badge';
    badge.style.background = BRAND_COLORS[name] || '#1a3a6b';
    badge.textContent = name.slice(0,3).toUpperCase();

    var h3 = document.createElement('h3'); h3.textContent = name;
    var p = document.createElement('p'); p.textContent = BRAND_MODELS[name] || '';
    var lbl = document.createElement('div'); lbl.className = 'brand-select-lbl'; lbl.textContent = 'Sélectionner →';

    card.appendChild(badge); card.appendChild(h3); card.appendChild(p); card.appendChild(lbl);
    grid.appendChild(card);
  });

  // Autre marque
  var other = document.createElement('div');
  other.className = 'brand-card brand-other';
  other.setAttribute('data-name', 'Autre marque');
  other.setAttribute('data-models', '');
  other.setAttribute('data-other', '1');
  other.onclick = function(){ goToOrder(this); };
  var ob = document.createElement('div'); ob.className = 'brand-badge'; ob.style.background='#e8f0fc'; ob.style.color='#1a3a6b'; ob.style.fontSize='1.5rem'; ob.textContent='🔧';
  var oh3 = document.createElement('h3'); oh3.textContent = 'Autre marque';
  var op = document.createElement('p'); op.textContent = 'Marque non listée';
  var olbl = document.createElement('div'); olbl.className = 'brand-select-lbl'; olbl.textContent = 'Saisir ma marque →';
  other.appendChild(ob); other.appendChild(oh3); other.appendChild(op); other.appendChild(olbl);
  grid.appendChild(other);

  showPage('page-marques');
}

// COMMANDE DEPUIS MARQUE
function goToOrder(el){
  var name = el.getAttribute('data-name');
  var models = el.getAttribute('data-models');
  var isOther = el.getAttribute('data-other') === '1';
  selectedBrand = {name:name, models:models, isOther:isOther};
  var cat = null;
  for(var i=0;i<CATS.length;i++){ if(CATS[i].id===selectedCategory){ cat=CATS[i]; break; } }
  var info = document.getElementById('orderBrandInfo');
  if(isOther){
    info.style.display = 'none';
    document.getElementById('otherBrandField').classList.add('visible');
  } else {
    info.style.display = 'flex';
    info.innerHTML = '';
    var ico = document.createElement('div'); ico.className = 'obi-ico';
    var badge = document.createElement('div');
    badge.style.cssText = 'width:40px;height:40px;border-radius:8px;display:flex;align-items:center;justify-content:center;font-family:Exo 2,sans-serif;font-size:0.8rem;font-weight:900;color:#fff;background:' + (BRAND_COLORS[name]||'#1a3a6b');
    badge.textContent = name.slice(0,3).toUpperCase();
    ico.appendChild(badge);
    var inf = document.createElement('div'); inf.className = 'obi-info';
    var strong = document.createElement('strong'); strong.textContent = name;
    var span = document.createElement('span'); span.textContent = models + (cat ? ' · ' + cat.label : '');
    inf.appendChild(strong); inf.appendChild(span);
    info.appendChild(ico); info.appendChild(inf);
    document.getElementById('otherBrandField').classList.remove('visible');
  }
  document.getElementById('orderFormWrap').style.display = 'block';
  document.getElementById('orderSuccess').style.display = 'none';
  showPage('page-order');
}

function submitOrder(){
  var modele = document.getElementById('o-modele').value.trim();
  var annee = document.getElementById('o-annee').value.trim();
  var piece = document.getElementById('o-piece').value.trim();
  var nom = document.getElementById('o-nom').value.trim();
  var email = document.getElementById('o-email').value.trim();
  var tel = document.getElementById('o-tel').value.trim();
  var note = document.getElementById('o-note').value.trim();
  var autreMarque = document.getElementById('o-autreMarque').value.trim();
  if(!modele||!piece||!nom||!tel){ alert('Veuillez remplir les champs obligatoires (*)'); return; }
  var marque = selectedBrand && selectedBrand.isOther ? (autreMarque || 'Autre') : (selectedBrand ? selectedBrand.name : '');
  var cat = null;
  for(var i=0;i<CATS.length;i++){ if(CATS[i].id===selectedCategory){ cat=CATS[i]; break; } }
  var order = {id:Date.now(), date:new Date().toLocaleString('fr-FR'), marque:marque, categorie:cat?cat.label:'', modele:modele, annee:annee, piece:piece, nom:nom, email:email, tel:tel, note:note, status:'new'};
  orders.unshift(order); saveOrders(); updateAdminBadge();
  document.getElementById('orderFormWrap').style.display = 'none';
  document.getElementById('orderSuccess').style.display = 'block';
}

function resetOrderForm(){
  document.getElementById('orderFormWrap').style.display = 'block';
  document.getElementById('orderSuccess').style.display = 'none';
  ['o-modele','o-annee','o-piece','o-nom','o-email','o-tel','o-note','o-autreMarque'].forEach(function(id){ var el=document.getElementById(id); if(el) el.value=''; });
}

// COMMANDE DIRECTE
function toggleOtherDirect(sel){
  var f = document.getElementById('otherBrandDirect');
  if(sel.value === 'Autre') f.classList.add('visible');
  else f.classList.remove('visible');
}

function submitDirectOrder(){
  var marque = document.getElementById('d-marque').value.trim();
  var modele = document.getElementById('d-modele').value.trim();
  var annee = document.getElementById('d-annee').value.trim();
  var cat = document.getElementById('d-categorie').value.trim();
  var piece = document.getElementById('d-piece').value.trim();
  var nom = document.getElementById('d-nom').value.trim();
  var email = document.getElementById('d-email').value.trim();
  var tel = document.getElementById('d-tel').value.trim();
  var note = document.getElementById('d-note').value.trim();
  var autre = document.getElementById('d-autreMarque').value.trim();
  if(!nom||!tel||!piece){ alert('Veuillez remplir au minimum : nom, téléphone et pièce'); return; }
  var marqueFinale = marque === 'Autre' ? (autre || 'Autre') : marque;
  var order = {id:Date.now(), date:new Date().toLocaleString('fr-FR'), marque:marqueFinale, categorie:cat, modele:modele, annee:annee, piece:piece, nom:nom, email:email, tel:tel, note:note, status:'new'};
  orders.unshift(order); saveOrders(); updateAdminBadge();
  document.getElementById('directFormWrap').style.display = 'none';
  document.getElementById('directOrderSuccess').style.display = 'block';
}

function resetDirectForm(){
  document.getElementById('directFormWrap').style.display = 'block';
  document.getElementById('directOrderSuccess').style.display = 'none';
  ['d-modele','d-annee','d-piece','d-nom','d-email','d-tel','d-note','d-autreMarque'].forEach(function(id){ var el=document.getElementById(id); if(el) el.value=''; });
  document.getElementById('d-marque').value = '';
  document.getElementById('d-categorie').value = '';
}

// CATALOGUE
function initCatalogue(){ buildFilters(); renderCatalogue(); }

function buildFilters(){
  var cats = {};
  products.forEach(function(p){ cats[p.cat] = true; });
  var bar = document.getElementById('filtersBar');
  var search = bar.querySelector('.filter-search');
  bar.innerHTML = '';
  var allBtn = document.createElement('button');
  allBtn.className = 'filter-btn' + (currentCatFilter==='all'?' active':'');
  allBtn.textContent = 'Tout voir';
  allBtn.onclick = function(){ currentCatFilter='all'; bar.querySelectorAll('.filter-btn').forEach(function(b){b.classList.remove('active');}); allBtn.classList.add('active'); renderCatalogue(); };
  bar.appendChild(allBtn);
  Object.keys(cats).forEach(function(c){
    var btn = document.createElement('button');
    btn.className = 'filter-btn' + (currentCatFilter===c?' active':'');
    btn.textContent = (CAT_EMOJIS[c]||'') + ' ' + c;
    btn.onclick = function(){ currentCatFilter=c; bar.querySelectorAll('.filter-btn').forEach(function(b){b.classList.remove('active');}); btn.classList.add('active'); renderCatalogue(); };
    bar.appendChild(btn);
  });
  bar.appendChild(search);
}

function filterCat(cat, el){ currentCatFilter=cat; document.querySelectorAll('.filter-btn').forEach(function(b){b.classList.remove('active');}); if(el)el.classList.add('active'); renderCatalogue(); }

function renderCatalogue(){
  var q = (document.getElementById('searchInput')||{value:''}).value.toLowerCase();
  var filtered = products.filter(function(p){
    var mc = currentCatFilter==='all' || p.cat===currentCatFilter;
    var ms = p.nom.toLowerCase().includes(q) || p.desc.toLowerCase().includes(q) || p.cat.toLowerCase().includes(q);
    return mc && ms;
  });
  var grid = document.getElementById('productsGrid');
  document.getElementById('prodCount').textContent = filtered.length;
  if(!filtered.length){
    grid.innerHTML = '<div class="no-results"><div class="big">🔍</div><p>Aucune pièce trouvée. <button style="background:none;border:none;color:var(--bl);font-weight:700;cursor:pointer;" onclick="showPage(\'page-order-direct\')">Commandez directement</button></p></div>';
    return;
  }
  var html = '';
  filtered.forEach(function(p){
    var price = Number(p.prix).toLocaleString('fr-FR');
    var newBadge = p.isNew ? '<span class="badge-new">NOUVEAU</span>' : '';
    var emoji = p.emoji || CAT_EMOJIS[p.cat] || '🔧';
    var imgHtml = p.photo ? '<img src="' + p.photo + '" alt="' + p.nom + '"/>' : emoji;
    var safeName = p.nom.replace(/"/g,'&quot;');
    html += '<div class="product-card">';
    html += '<div class="product-img">' + imgHtml + '</div>';
    html += '<div class="product-body">';
    html += '<div class="product-cat">' + p.cat + newBadge + '</div>';
    html += '<h3>' + p.nom + '</h3>';
    html += '<p>' + p.desc + '</p>';
    html += '<div class="product-footer">';
    html += '<div class="product-price">' + price + ' FCFA</div>';
    html += '<button class="product-btn" data-nom="' + safeName + '" data-cat="' + p.cat + '" onclick="orderFromBtn(this)">Commander</button>';
    html += '</div></div></div>';
  });
  grid.innerHTML = html;
}

function orderFromBtn(btn){
  document.getElementById('d-piece').value = btn.getAttribute('data-nom');
  document.getElementById('d-categorie').value = btn.getAttribute('data-cat');
  document.getElementById('directFormWrap').style.display = 'block';
  document.getElementById('directOrderSuccess').style.display = 'none';
  showPage('page-order-direct');
}

// AUTH
function doLogin(){
  if(document.getElementById('pwdInput').value === PASS){
    showPage('page-admin'); renderAdminTable(); renderOrders(); updateStats();
  } else {
    document.getElementById('loginError').style.display = 'block';
  }
}

// ADMIN ONGLETS
function switchTab(tabId, btn){
  document.querySelectorAll('.tab-panel').forEach(function(p){p.classList.remove('active');});
  document.querySelectorAll('.admin-tab').forEach(function(b){b.classList.remove('active');});
  document.getElementById(tabId).classList.add('active');
  btn.classList.add('active');
  if(tabId==='tab-orders') renderOrders();
}

// PHOTO
function previewPhoto(input){
  if(!input.files||!input.files[0]) return;
  var file = input.files[0];
  if(file.size > 5*1024*1024){ alert('Image trop lourde (max 5 Mo)'); input.value=''; return; }
  var reader = new FileReader();
  reader.onload = function(e){
    currentPhotoBase64 = e.target.result;
    document.getElementById('photoPreviewImg').src = e.target.result;
    document.getElementById('photoPreview').style.display = 'block';
    document.getElementById('photoZone').style.display = 'none';
  };
  reader.readAsDataURL(file);
}
function removePhoto(e){
  e.stopPropagation();
  currentPhotoBase64 = '';
  document.getElementById('photoPreview').style.display = 'none';
  document.getElementById('photoZone').style.display = 'block';
  document.getElementById('a-photo').value = '';
}

// ADMIN CATALOGUE
function addProduct(){
  var nom = document.getElementById('a-nom').value.trim();
  var cat = document.getElementById('a-cat').value;
  var prix = document.getElementById('a-prix').value.trim();
  var desc = document.getElementById('a-desc').value.trim();
  var isNew = document.getElementById('a-new').checked;
  if(!nom||!prix||!desc){ alert('Remplissez les champs obligatoires (*)'); return; }
  products.unshift({id:Date.now(), nom:nom, cat:cat, prix:prix, desc:desc, photo:currentPhotoBase64, isNew:isNew, date:new Date().toLocaleDateString('fr-FR')});
  saveProducts(); renderAdminTable(); updateStats();
  document.getElementById('a-nom').value=''; document.getElementById('a-prix').value=''; document.getElementById('a-desc').value='';
  document.getElementById('a-new').checked=false; removePhoto({stopPropagation:function(){}});
  var s=document.getElementById('addSuccess'); s.style.display='block'; setTimeout(function(){s.style.display='none';},3000);
}

function deleteProduct(id){
  id = Number(id);
  if(!confirm('Supprimer cette pièce ?')) return;
  products = products.filter(function(p){return p.id!==id;});
  saveProducts(); renderAdminTable(); updateStats();
}

function renderAdminTable(){
  var tb = document.getElementById('adminTbody');
  if(!products.length){ tb.innerHTML='<tr><td colspan="4" class="empty-t">Aucune pièce ajoutée</td></tr>'; return; }
  var rows = '';
  products.forEach(function(p){
    var price = Number(p.prix).toLocaleString('fr-FR');
    var emoji = CAT_EMOJIS[p.cat] || '🔧';
    var newBadge = p.isNew ? '<span style="font-size:0.6rem;background:#e74c3c;color:#fff;padding:2px 6px;border-radius:2px;margin-left:4px;">NEW</span>' : '';
    var imgContent = p.photo ? '<img src="' + p.photo + '" style="width:44px;height:44px;object-fit:cover;border-radius:6px;">' : '<div style="width:44px;height:44px;background:var(--bvp);border-radius:6px;display:flex;align-items:center;justify-content:center;font-size:1.3rem;">' + emoji + '</div>';
    rows += '<tr><td><div style="display:flex;align-items:center;gap:10px;">' + imgContent + '<div><strong>' + p.nom + '</strong><br><span style="font-size:0.7rem;color:var(--tl);">' + p.date + '</span></div></div></td>';
    rows += '<td><span class="tcat">' + p.cat + '</span>' + newBadge + '</td>';
    rows += '<td class="tprice">' + price + '</td>';
    rows += '<td><button class="tdel" onclick="deleteProduct(' + p.id + ')">🗑️</button></td></tr>';
  });
  tb.innerHTML = rows;
}

// ADMIN COMMANDES
function filterOrders(f, el){
  ordersFilter = f;
  document.querySelectorAll('.ofilter').forEach(function(b){b.classList.remove('active');});
  if(el) el.classList.add('active');
  renderOrders();
}

function renderOrders(){
  var list = document.getElementById('ordersList');
  var filtered = orders;
  if(ordersFilter==='new') filtered = orders.filter(function(o){return o.status==='new';});
  if(ordersFilter==='done') filtered = orders.filter(function(o){return o.status==='done';});
  if(!filtered.length){ list.innerHTML='<div class="no-orders"><div style="font-size:2.5rem;margin-bottom:8px;">📭</div><p style="font-weight:700;color:var(--tx);">Aucune commande</p><p style="font-size:0.83rem;">Les commandes apparaîtront ici.</p></div>'; return; }
  var html = '';
  filtered.forEach(function(o){
    var sCls = o.status==='new' ? 's-new' : 's-done';
    var sTxt = o.status==='new' ? '⏳ En attente' : '✅ Traitée';
    var treatTxt = o.status==='new' ? '✅ Marquer traitée' : '↩️ En attente';
    html += '<div class="order-card">';
    html += '<div class="oc-head"><span class="oc-id">🧾 #' + String(o.id).slice(-6) + '</span><span class="oc-date">📅 ' + o.date + '</span><span class="oc-status ' + sCls + '">' + sTxt + '</span></div>';
    html += '<div class="oc-body">';
    html += '<div class="ocf"><div class="lbl">Client</div><div class="val">👤 ' + o.nom + '</div></div>';
    html += '<div class="ocf"><div class="lbl">Téléphone</div><div class="val">📞 ' + o.tel + '</div></div>';
    html += '<div class="ocf"><div class="lbl">Email</div><div class="val">📧 ' + (o.email||'—') + '</div></div>';
    html += '<div class="ocf"><div class="lbl">Marque</div><div class="val">🚗 ' + (o.marque||'—') + '</div></div>';
    html += '<div class="ocf"><div class="lbl">Modèle/Année</div><div class="val">' + (o.modele||'—') + (o.annee?' ('+o.annee+')':'') + '</div></div>';
    html += '<div class="ocf"><div class="lbl">Catégorie</div><div class="val">' + (o.categorie||'—') + '</div></div>';
    html += '<div class="ocf" style="grid-column:1/-1"><div class="lbl">Pièce recherchée</div><div class="val" style="font-weight:700;color:var(--b);">🔧 ' + o.piece + '</div></div>';
    if(o.note) html += '<div class="ocf" style="grid-column:1/-1"><div class="lbl">Notes</div><div class="val" style="font-style:italic;">' + o.note + '</div></div>';
    html += '</div>';
    html += '<div class="oc-foot"><button class="btn-treat" onclick="toggleOrderStatus(' + o.id + ')">' + treatTxt + '</button><button class="btn-del-o" onclick="deleteOrder(' + o.id + ')">🗑️ Supprimer</button></div>';
    html += '</div>';
  });
  list.innerHTML = html;
}

function toggleOrderStatus(id){
  var o = orders.find(function(x){return x.id===id;});
  if(o){ o.status = o.status==='new'?'done':'new'; saveOrders(); renderOrders(); updateStats(); updateAdminBadge(); }
}
function deleteOrder(id){
  if(!confirm('Supprimer cette commande ?')) return;
  orders = orders.filter(function(o){return o.id!==id;});
  saveOrders(); renderOrders(); updateStats(); updateAdminBadge();
}
function clearAllOrders(){
  if(!confirm('Effacer TOUTES les commandes ?')) return;
  orders = []; saveOrders(); renderOrders(); updateStats(); updateAdminBadge();
}

function updateAdminBadge(){
  var pending = orders.filter(function(o){return o.status==='new';}).length;
  var badge = document.getElementById('pendingBadge');
  if(badge){ badge.textContent=pending; badge.style.display=pending>0?'inline':'none'; }
}

function updateStats(){
  document.getElementById('st-total').textContent = products.length;
  document.getElementById('st-new').textContent = products.filter(function(p){return p.isNew;}).length;
  document.getElementById('st-orders').textContent = orders.length;
  var pending = orders.filter(function(o){return o.status==='new';}).length;
  document.getElementById('st-pending').textContent = pending;
  updateAdminBadge();
}

// REVEAL SCROLL
var obs = new IntersectionObserver(function(entries){ entries.forEach(function(e){ if(e.isIntersecting) e.target.classList.add('visible'); }); },{threshold:0.1});
document.querySelectorAll('.reveal').forEach(function(r){obs.observe(r);});

// INIT
initHome();
updateAdminBadge();
</script>
</body>
</html>
